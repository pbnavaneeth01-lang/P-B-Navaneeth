rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() { return request.auth != null; }
    function isOwner(uid) { return isAuthenticated() && request.auth.uid == uid; }
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "pbnavaneeth01@gmail.com" && request.auth.token.email_verified == true
      );
    }

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // - uid: string (required)
    // - displayName: string
    // - email: string
    // - photoURL: string
    // - createdAt: string (ISO 8601)

    // Collection: exams
    // - uid: string (required)
    // - title: string (required)
    // - questionPaperUrl: string (required)
    // - markingSchemeUrl: string (required)
    // - createdAt: string (ISO 8601)

    // Collection: submissions
    // - uid: string (required)
    // - examId: string (required)
    // - studentName: string (required)
    // - bookletUrl: string (required)
    // - status: string (pending|evaluated, required)
    // - totalMarks: number
    // - maxMarks: number
    // - evaluationData: map
    // - createdAt: string (ISO 8601)

    // Collection: history
    // - uid: string (required)
    // - type: string
    // - prompt: string
    // - resultUrl: string
    // - createdAt: string (ISO 8601)

    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /exams/{examId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isOwner(resource.data.uid) || isAdmin();
    }

    match /submissions/{submissionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isOwner(resource.data.uid) || isAdmin();
    }

    match /history/{historyId} {
      allow read: if isOwner(resource.data.uid) || isAdmin();
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isOwner(resource.data.uid) || isAdmin();
    }
  }
}
